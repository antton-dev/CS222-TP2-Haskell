:t halve
halve [1..10] 
-- ([1,3,5,7,9],[2,4,6,8,10])

halve [1..11]
-- ([1,3,5,7,9,11],[2,4,6,8,10])

halve []
-- ([], [])

:t combine
combine [1,2,6] [0,3,4,5,9]
-- [0,1,2,3,4,5,6,9]

combine [] []
-- []

combine [1,2,5,7]  []
-- [1,2,5,7]

:t tri_fusion
tri_fusion [20,14,3,5,0,65,23,14,75,16,28,95,10,54]
-- [0,3,5,10,14,14,16,20,23,28,54,65,75,95]